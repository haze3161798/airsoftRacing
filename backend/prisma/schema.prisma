generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tournament {
  id                  String    @id @default(uuid())
  slug                String    @unique @db.VarChar(50)
  name                String    @db.VarChar(200)
  description         String?   @db.Text
  rulesPdfUrl         String?   @db.VarChar(500) @map("rules_pdf_url")
  bannerUrl           String?   @db.VarChar(500) @map("banner_url")
  registrationOpenAt  DateTime? @map("registration_open_at") @db.Timestamptz
  registrationCloseAt DateTime? @map("registration_close_at") @db.Timestamptz
  isActive            Boolean   @default(false) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  teams   Team[]
  players Player[]

  @@map("tournament")
}

model Team {
  id              String    @id @default(uuid())
  tournamentId    String    @map("tournament_id")
  teamName        String    @db.VarChar(100) @map("team_name")
  status          String    @default("PENDING") @db.VarChar(20)
  paymentNote     String?   @db.VarChar(200) @map("payment_note")
  rejectionReason String?   @db.Text @map("rejection_reason")
  submittedAt     DateTime  @default(now()) @map("submitted_at") @db.Timestamptz
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players    Player[]

  @@unique([tournamentId, teamName])
  @@index([tournamentId])
  @@map("team")
}

model Player {
  id             String   @id @default(uuid())
  teamId         String   @map("team_id")
  tournamentId   String   @map("tournament_id")
  name           String   @db.VarChar(100)
  phone          String   @db.VarChar(128)
  nationalIdHash String   @db.VarChar(128) @map("national_id_hash")
  role           String   @db.VarChar(20)
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@index([teamId])
  @@map("player")
}

model Sponsor {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(100)
  imageData     Bytes    @map("image_data")
  imageMimeType String   @db.VarChar(50) @map("image_mime_type")
  linkUrl       String?  @db.VarChar(500) @map("link_url")
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  prizes Prize[]

  @@map("sponsor")
}

model PrizeTag {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  prizes Prize[]

  @@map("prize_tag")
}

model Prize {
  id            String    @id @default(uuid())
  sponsorId     String?   @map("sponsor_id")
  prizeTagId    String?   @map("prize_tag_id")
  name          String    @db.VarChar(200)
  description   String?   @db.Text
  imageData     Bytes     @map("image_data")
  imageMimeType String    @db.VarChar(50) @map("image_mime_type")
  isFeatured    Boolean   @default(false) @map("is_featured")
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  sponsor  Sponsor?  @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  prizeTag PrizeTag? @relation(fields: [prizeTagId], references: [id], onDelete: SetNull)

  @@index([sponsorId])
  @@index([prizeTagId])
  @@map("prize")
}
